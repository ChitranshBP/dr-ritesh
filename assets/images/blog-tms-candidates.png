<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a365d"/>
      <stop offset="50%" style="stop-color:#2c5282"/>
      <stop offset="100%" style="stop-color:#3182ce"/>
    </linearGradient>
    <linearGradient id="brainGlow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#4299e1"/>
      <stop offset="100%" style="stop-color:#63b3ed"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bgGrad)"/>

  <!-- Decorative circles -->
  <circle cx="100" cy="100" r="150" fill="#4299e1" opacity="0.1"/>
  <circle cx="1100" cy="530" r="200" fill="#63b3ed" opacity="0.1"/>
  <circle cx="900" cy="100" r="100" fill="#4299e1" opacity="0.08"/>

  <!-- Brain outline - simplified icon -->
  <g transform="translate(150, 165)" filter="url(#glow)">
    <!-- Brain shape -->
    <path d="M100,20 C140,10 180,30 190,70 C200,100 190,140 170,170 C150,200 110,210 80,200 C50,190 30,160 30,130 C30,100 50,70 80,50 C70,80 60,120 70,150 C40,140 20,110 25,80 C30,50 60,30 100,20 Z"
          fill="none" stroke="#63b3ed" stroke-width="3" opacity="0.8"/>
    <!-- Brain folds -->
    <path d="M60,80 Q90,60 120,85" fill="none" stroke="#90cdf4" stroke-width="2" opacity="0.6"/>
    <path d="M50,120 Q80,100 110,125" fill="none" stroke="#90cdf4" stroke-width="2" opacity="0.6"/>
    <path d="M70,160 Q100,140 130,165" fill="none" stroke="#90cdf4" stroke-width="2" opacity="0.6"/>
    <!-- TMS waves -->
    <circle cx="170" cy="90" r="15" fill="none" stroke="#48bb78" stroke-width="2" opacity="0.8"/>
    <circle cx="170" cy="90" r="25" fill="none" stroke="#48bb78" stroke-width="2" opacity="0.5"/>
    <circle cx="170" cy="90" r="35" fill="none" stroke="#48bb78" stroke-width="2" opacity="0.3"/>
    <!-- Pulse dots -->
    <circle cx="170" cy="90" r="5" fill="#48bb78"/>
  </g>

  <!-- TMS coil icon -->
  <g transform="translate(280, 280)">
    <ellipse cx="0" cy="0" rx="40" ry="25" fill="none" stroke="#f6e05e" stroke-width="3"/>
    <line x1="0" y1="25" x2="0" y2="60" stroke="#f6e05e" stroke-width="3"/>
    <circle cx="0" cy="-30" r="8" fill="#f6e05e"/>
  </g>

  <!-- Checkmark icons -->
  <g transform="translate(100, 400)">
    <circle cx="15" cy="15" r="15" fill="#48bb78"/>
    <path d="M8,15 L13,20 L22,10" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    <text x="45" y="20" fill="white" font-family="Arial, sans-serif" font-size="16" opacity="0.9">Depression not responding to medications</text>
  </g>

  <g transform="translate(100, 450)">
    <circle cx="15" cy="15" r="15" fill="#48bb78"/>
    <path d="M8,15 L13,20 L22,10" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    <text x="45" y="20" fill="white" font-family="Arial, sans-serif" font-size="16" opacity="0.9">Looking for non-invasive treatment options</text>
  </g>

  <g transform="translate(100, 500)">
    <circle cx="15" cy="15" r="15" fill="#48bb78"/>
    <path d="M8,15 L13,20 L22,10" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    <text x="45" y="20" fill="white" font-family="Arial, sans-serif" font-size="16" opacity="0.9">Seeking hope for lasting mental wellness</text>
  </g>

  <!-- Main title -->
  <text x="380" y="150" fill="white" font-family="Georgia, serif" font-size="52" font-weight="bold">
    Who Is a Good Candidate
  </text>
  <text x="380" y="210" fill="white" font-family="Georgia, serif" font-size="52" font-weight="bold">
    for TMS Therapy?
  </text>

  <!-- Subtitle -->
  <text x="380" y="270" fill="#bee3f8" font-family="Arial, sans-serif" font-size="22">
    Discover if Transcranial Magnetic Stimulation
  </text>
  <text x="380" y="300" fill="#bee3f8" font-family="Arial, sans-serif" font-size="22">
    could be your path to relief
  </text>

  <!-- TMS label badge -->
  <rect x="380" y="330" width="180" height="40" rx="20" fill="#48bb78"/>
  <text x="470" y="357" fill="white" font-family="Arial, sans-serif" font-size="18" font-weight="bold" text-anchor="middle">
    TMS THERAPY
  </text>

  <!-- Bottom info bar -->
  <rect x="0" y="580" width="1200" height="50" fill="rgba(0,0,0,0.3)"/>
  <text x="50" y="612" fill="#bee3f8" font-family="Arial, sans-serif" font-size="14">
    Dr. Ritesh Patel | TMS Treatment Specialist
  </text>
  <text x="600" y="612" fill="#bee3f8" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">
    Atlanta TMS Therapy
  </text>
  <text x="1150" y="612" fill="#bee3f8" font-family="Arial, sans-serif" font-size="14" text-anchor="end">
    Brain Health | Mental Wellness
  </text>
</svg>